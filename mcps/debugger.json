{
  "mcpServers": {
    "windbg": {
      "command": "python",
      "args": ["-m", "mcp_windbg"],
      "env": {
        "_NT_SYMBOL_PATH": "SRV*C:\\Symbols*https://msdl.microsoft.com/download/symbols"
      },
      "disabled": false,
      "autoApprove": [],
      "_comment": "Windows: CDB/WinDbg crash dump analysis & remote debugging (svnscha/mcp-windbg, pip install mcp-windbg)"
    },
    "gdb": {
      "command": "uvx",
      "args": ["mcp-gdb"],
      "env": {},
      "disabled": false,
      "autoApprove": [],
      "_comment": "Linux: GDB debugger MCP (signal-slot/mcp-gdb)"
    }
  }
}
